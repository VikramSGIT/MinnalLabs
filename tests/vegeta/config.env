# Vegeta-based phase harness configuration.
# Edit these values before running `tests/vegeta/run.sh` or the stress runner service.

STRESS_PRODUCT_PREFIX=stress-product-
STRESS_EXPECTED_PRODUCT_COUNT=20

STRESS_USER_COUNT=200
STRESS_HOMES_PER_USER=2
STRESS_DEVICES_PER_HOME=20
STRESS_DELETE_DEVICES_PER_USER=10
STRESS_DELETE_HOMES_PER_USER=1
STRESS_DELETE_HOME_SLOT=0
STRESS_DELETE_USERS_SELF_COUNT=100
STRESS_DELETE_USERS_SELF_START_INDEX=0
STRESS_DELETE_USERS_ADMIN_COUNT=100
STRESS_DELETE_USERS_ADMIN_START_INDEX=100
STRESS_FULFILLMENT_REQUESTS_PER_DEVICE=6
STRESS_FULFILLMENT_DEVICE_LIMIT=8000

STRESS_HTTP_TIMEOUT=30s
STRESS_PHASE_BUFFER_SECONDS=0
WAIT_TIMEOUT_SECONDS=180
ASYNC_HOME_READY_TIMEOUT_MS=120000
ASYNC_HOME_READY_POLL_MS=1000
ASYNC_HOME_EARLY_READY_CHECK_MS=3000
ASYNC_DRAIN_WAIT_SECONDS=30
ASYNC_DRAIN_POLL_INTERVAL_SECONDS=1
PPROF_PHASE_SECONDS=10

# --- create_users: 200 items in ~60s ---
VEGETA_CREATE_USERS_WORKERS=64
VEGETA_CREATE_USERS_START_RPS=1
VEGETA_CREATE_USERS_PEAK_RPS=10
VEGETA_CREATE_USERS_RAMP_UP_SECONDS=10
VEGETA_CREATE_USERS_HOLD_SECONDS=25
VEGETA_CREATE_USERS_RAMP_DOWN_SECONDS=10
VEGETA_CREATE_USERS_MAX_DURATION=2m

# --- google_oauth_enroll: 200 items (one per user) in ~60s ---
VEGETA_GOOGLE_OAUTH_ENROLL_WORKERS=64
VEGETA_GOOGLE_OAUTH_ENROLL_START_RPS=1
VEGETA_GOOGLE_OAUTH_ENROLL_PEAK_RPS=10
VEGETA_GOOGLE_OAUTH_ENROLL_RAMP_UP_SECONDS=10
VEGETA_GOOGLE_OAUTH_ENROLL_HOLD_SECONDS=25
VEGETA_GOOGLE_OAUTH_ENROLL_RAMP_DOWN_SECONDS=10
VEGETA_GOOGLE_OAUTH_ENROLL_MAX_DURATION=2m

# --- create_homes: 400 items in ~60s ---
VEGETA_CREATE_HOMES_WORKERS=64
VEGETA_CREATE_HOMES_START_RPS=1
VEGETA_CREATE_HOMES_PEAK_RPS=15
VEGETA_CREATE_HOMES_RAMP_UP_SECONDS=10
VEGETA_CREATE_HOMES_HOLD_SECONDS=25
VEGETA_CREATE_HOMES_RAMP_DOWN_SECONDS=10
VEGETA_CREATE_HOMES_MAX_DURATION=5m

# --- enroll_devices: 8000 items in ~60s ---
VEGETA_ENROLL_DEVICES_WORKERS=256
VEGETA_ENROLL_DEVICES_START_RPS=10
VEGETA_ENROLL_DEVICES_PEAK_RPS=200
VEGETA_ENROLL_DEVICES_RAMP_UP_SECONDS=15
VEGETA_ENROLL_DEVICES_HOLD_SECONDS=30
VEGETA_ENROLL_DEVICES_RAMP_DOWN_SECONDS=15
VEGETA_ENROLL_DEVICES_MAX_DURATION=5m

# --- fulfillment_mix: 48000 items ---
VEGETA_FULFILLMENT_MIX_WORKERS=1024
VEGETA_FULFILLMENT_MIX_START_RPS=10
VEGETA_FULFILLMENT_MIX_PEAK_RPS=400
VEGETA_FULFILLMENT_MIX_RAMP_UP_SECONDS=15
