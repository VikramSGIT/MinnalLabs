# --- delete_devices: 2000 items ---
VEGETA_DELETE_DEVICES_WORKERS=128
VEGETA_DELETE_DEVICES_START_RPS=5
VEGETA_DELETE_DEVICES_PEAK_RPS=80
VEGETA_DELETE_DEVICES_RAMP_UP_SECONDS=10
