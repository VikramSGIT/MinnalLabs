# --- delete_homes: 200 items ---
VEGETA_DELETE_HOMES_WORKERS=32
VEGETA_DELETE_HOMES_START_RPS=1
VEGETA_DELETE_HOMES_PEAK_RPS=10
VEGETA_DELETE_HOMES_RAMP_UP_SECONDS=10
VEGETA_DELETE_HOMES_HOLD_SECONDS=20
VEGETA_DELETE_HOMES_RAMP_DOWN_SECONDS=10
VEGETA_DELETE_HOMES_MAX_DURATION=2m

# --- delete_users_self: 100 items ---
VEGETA_DELETE_USERS_SELF_WORKERS=16
VEGETA_DELETE_USERS_SELF_START_RPS=1
VEGETA_DELETE_USERS_SELF_PEAK_RPS=10
VEGETA_DELETE_USERS_SELF_RAMP_UP_SECONDS=10
