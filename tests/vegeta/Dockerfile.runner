FROM golang:1.25-alpine

WORKDIR /app

ENV PATH="/usr/local/go/bin:${PATH}"

RUN apk add --no-cache \
        bash \
        ca-certificates \
        curl \
        graphviz \
        postgresql-client \
        python3 \
    && update-ca-certificates \
    && ln -sf /usr/local/go/bin/go /usr/local/bin/go

ENTRYPOINT ["bash", "/app/tests/vegeta/run.sh"]
